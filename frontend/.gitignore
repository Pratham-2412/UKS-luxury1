# =========================
.env
backend/.env
frontend/.env

# =========================
# Logs
# =========================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Build folders
# =========================
dist/
build/
frontend/dist/
backend/dist/

# =========================
# Vite cache
